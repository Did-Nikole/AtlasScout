# Ignore all files and folders starting with a dot
.*

# Allow tracking of the .gitignore file itself
!.gitignore

# Ignore build artifacts and object directories
build/

# Ignore test files directory
testfiles/

# Ignore generated plugins directory
plugins/

# Ignore compiled executables
atlasscout
example_main

# Ignore compilation database generated by compiledb
compile_commands.json

tests